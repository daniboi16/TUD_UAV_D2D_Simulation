            <property name="styleSheet">
             <string notr="true">/* Main Container Styling */
QFrame#infobox {
    background-color: #252526;
    border: 1px solid #3e3e42;
    border-radius: 4px;
}

/* Common Header Label Styling */
QLabel {
    color: #bdc3c7;
    font-family: 'Segoe UI', sans-serif;
    font-size: 11px;
    border: none;
    background: transparent;
}

/* Data Value Styling (the actual info) */
QLabel[objectName$=&quot;Data&quot;] {
    color: #ffffff;
    font-weight: bold;
    font-size: 12px;
}

QFrame#node_title, QFrame#msg_title {
    border-bottom: 1px solid #3e3e42; /* A subtle divider line */
    margin-bottom: 5px;
}</string>
